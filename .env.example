# GoDaddy / Microsoft 365 Email credentials
EMAIL_USER=info@yourdomain.com
EMAIL_PASS=your_email_password

# Optional SMTP Settings (Defaults to GoDaddy Office 365)
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# Where to receive enquiries (defaults to EMAIL_USER if omitted)
EMAIL_TO=info@yourdomain.com

# Allowed frontend origin (for CORS in production)
CLIENT_ORIGIN=http://localhost:5173

# Groq API key — get yours at console.groq.com
GROQ_API_KEY=your_groq_api_key_here
